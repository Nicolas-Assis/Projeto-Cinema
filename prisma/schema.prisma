generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum GeneroFilme {
  ACAO
  AVENTURA
  COMEDIA
  DRAMA
  FANTASIA
  FICCAO_CIENTIFICA
  TERROR
  ROMANCE
  ANIMACAO
  DOCUMENTARIO
  SUSPENSE
  MUSICAL
  OUTRO
}

model Cinema {
  id        Int      @id @default(autoincrement())
  nome      String
  endereco  String
  salas     Sala[]
  sessoes   Sessao[]
  filmes    Filme[]  @relation("CinemaFilme")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Sala {
  id         Int      @id @default(autoincrement())
  numero     Int
  capacidade Int
  poutronas  Json
  cinemaId   Int
  cinema     Cinema   @relation(fields: [cinemaId], references: [id], onDelete: Cascade)
  sessoes    Sessao[]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Filme {
  id                 Int         @id @default(autoincrement())
  titulo             String
  sinopse            String
  classificacao      String
  duracao            Int
  elenco             String
  genero             GeneroFilme
  dataIniciaExibicao DateTime
  dataFinalExibicao  DateTime
  cinemas            Cinema[]    @relation("CinemaFilme")
  sessoes            Sessao[]
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
}

model Sessao {
  id              Int        @id @default(autoincrement())
  horarioExibicao DateTime
  filmeId         Int
  filme           Filme      @relation(fields: [filmeId], references: [id], onDelete: Restrict)
  salaId          Int
  sala            Sala       @relation(fields: [salaId], references: [id], onDelete: Restrict)
  cinemaId        Int
  cinema          Cinema     @relation(fields: [cinemaId], references: [id], onDelete: Cascade)
  ingressos       Ingresso[]
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
}

model Ingresso {
  id           Int      @id @default(autoincrement())
  valorInteira Float
  valorMeia    Float
  sessaoId     Int
  sessao       Sessao   @relation(fields: [sessaoId], references: [id], onDelete: Cascade)
  pedidos      Pedido[] @relation("PedidoIngresso")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Pedido {
  id         Int           @id @default(autoincrement())
  qtInteira  Int
  qtMeia     Int
  valorTotal Float
  ingressos  Ingresso[]    @relation("PedidoIngresso")
  lanches    LancheCombo[]
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
}

model LancheCombo {
  id            Int      @id @default(autoincrement())
  nome          String
  descricao     String
  valorUnitario Float
  qtUnidade     Int
  subtotal      Float
  pedidoId      Int
  pedido        Pedido   @relation(fields: [pedidoId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
